# SIMON-TECH-BOT Environment Variables
# Copy this file to .env and fill in your values

# WhatsApp Session ID (Generated from session-generator)
SESSION_ID=your_session_id_here

# Bot Configuration
BOT_NAME=SIMON
BOT_PREFIX=.
BOT_VERSION=2.0.0
BOT_MODE=private

# Owner Information
OWNER_NUMBER=2349166265317
OWNER_NAME=SIMON TECH

# API Keys (Optional - for AI and other features)
OPENAI_API_KEY=your_openai_key_here
RAPIDAPI_KEY=your_rapidapi_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here

# Database (Optional)
MONGODB_URI=your_mongodb_uri_here
DB_NAME=simon_bot

# Features Toggle
ENABLE_AI=true
ENABLE_GAMES=true
ENABLE_ECONOMY=true
ENABLE_SECURITY=true
ENABLE_AUTO_REPLY=true
ENABLE_NSFW=false

# Auto Features
AUTO_READ_STATUS=false
AUTO_READ_MESSAGES=false
AUTO_TYPING=false
AUTO_RECORDING=false
AUTO_REACT=false

# Security
ANTILINK=true
ANTISPAM=true
ANTIBOT=true
ANTIFAKE=true

# Debug Mode
DEBUG=false
LOG_LEVEL=info

# Server
PORT=3000
NODE_ENV=production
